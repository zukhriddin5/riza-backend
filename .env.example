# Copy to .env for local dev. In production (DigitalOcean) set these in the
# App Platform "Environment Variables" panel — do NOT commit real secrets.

# --- Database (Neon Postgres) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# --- Auth ---
JWT_SECRET="change-this-to-a-long-random-string"
JWT_EXPIRES_IN="1d"

# --- Shipping (integer cents) ---
FREE_SHIPPING_THRESHOLD=50000   # 50000 = $500
SHIPPING_FEE=5000               # 5000  = $50

# --- Store payment info (shown at checkout for card payments) ---
ADMIN_TELEGRAM=@riza_admin
ADMIN_CARD_NUMBER=8600 1234 5678 9012

# --- CORS: the deployed frontend origin (your Vercel URL in prod) ---
FRONTEND_URL=http://localhost:3001

# --- File storage: "local" (dev) or "s3" (prod: R2 / DO Spaces / S3) ---
STORAGE_DRIVER=local
APP_URL=http://localhost:3000   # public base URL of THIS API (for local image URLs)

# --- S3-compatible storage (only used when STORAGE_DRIVER=s3) ---
# Cloudflare R2 example:
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=riza-images
S3_ACCESS_KEY_ID=<r2-access-key-id>
S3_SECRET_ACCESS_KEY=<r2-secret-access-key>
S3_PUBLIC_URL=https://<your-r2-public-or-custom-domain>
